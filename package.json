{
  "name": "lsp-d-planner-plus",
  "version": "2.53.04",
  "description": "LSP D-Planner+ \u2014 unified OC + CCR decompression planning app",
  "private": true,
  "scripts": {
    "build": "npm run build:bundles && npm run check:engine-parity",
    "build:bundles": "python tools/build_zhl_bundle.py && python tools/build_vpm_bundle.py",
    "check:engine-parity": "python tools/check_engine_parity.py",
    "audit:coverage": "python tools/audit_coverage.py --check",
    "test:audit-coverage": "python tools/test_audit_coverage.py",
    "test": "python dev/run_all_regression.py --tier release",
    "test:ci": "python dev/run_all_regression.py --tier ci",
    "vendor:offline": "python tools/vendor_offline_assets.py",
    "sync:www": "python tools/sync_www.py",
    "cap:sync": "npm run sync:www && npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capawesome-team/capacitor-file-opener": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1"
  },
  "engines": {
    "node": ">=22"
  }
}
