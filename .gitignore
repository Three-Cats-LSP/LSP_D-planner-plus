# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# Node / Capacitor
node_modules/
www/

# Android build artifacts
android/.gradle/
android/build/
android/app/build/
android/local.properties
# Capacitor copies web assets here — do not track
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# Local / CI test output
audit-out.txt
dev/browser_regression_results.json
dev/ccr_differential_report.json
dev/pscr_e2e_results.json
docs/CCR_DIFFERENTIAL_REPORT.md

# Python bytecode (must not be tracked — recompiled on every test run)
__pycache__/
*.py[cod]
